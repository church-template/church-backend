# 교회 식별
CHURCH_KEY=

# PostgreSQL
DB_NAME=church_db
DB_URL=jdbc:postgresql://postgres:5432/church_db
DB_USERNAME=church_user
DB_PASSWORD=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — 교회마다 반드시 다른 값
JWT_SECRET=
JWT_ACCESS_EXPIRY=3600
JWT_REFRESH_EXPIRY=1209600

# CORS — 해당 교회 프론트 도메인
CORS_ALLOWED_ORIGIN=https://example.kr

# 파일 저장
FILE_UPLOAD_DIR=/app/uploads
FILE_BASE_URL=https://example.kr/api/media
FILE_MAX_SIZE=10485760       # 업로드 최대 크기(바이트). 운영자 조정값, 기본 10MB. 초과 시 업로드 거부

# Swagger 노출 (운영은 false 권장)
SWAGGER_ENABLED=false

# 최초 SUPER_ADMIN 부트스트랩 — 기동 시 활성 SUPER_ADMIN이 없을 때만 1회 생성(멱등).
# 세 값이 모두 채워져야 동작. 최초 로그인 후 비밀번호를 반드시 변경할 것.
ADMIN_PHONE=
ADMIN_NAME=
ADMIN_PASSWORD=
